{
  "expo": {
    "name": "BankaiMusic",
    "slug": "bankaimusic",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "bankaimusic",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "backgroundColor": "#FEF9EF",
    "splash": {
      "backgroundColor": "#FEF9EF",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bankaimusic.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "NSAppleMusicUsageDescription": "BankaiMusic needs access to your music library to find and play the songs stored on your device.",
        "UIFileSharingEnabled": true,
        "LSSupportsOpeningDocumentsInPlace": true
      }
    },
    "android": {
      "package": "com.bankaimusic.app",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#FEF9EF"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-media-library",
        {
          "photosPermission": false,
          "savePhotosPermission": false,
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "BankaiMusic uses the microphone to identify a song playing nearby."
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fc159395-8316-4756-9698-a3029974ce02"
      }
    },
    "owner": "algedon1471s-team"
  }
}
