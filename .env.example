# Copy this file to `.env` (git-ignored) and fill in your own values.
# Never commit real credentials — `.env` is excluded in .gitignore.

# Spotify Developer Dashboard (developer.spotify.com/dashboard) — PKCE client,
# no secret. Register redirect URI: bankaimusic://connect/spotify
# Safe to expose client-side — that's what EXPO_PUBLIC_ means.
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=

# Google Cloud Console (console.cloud.google.com) — OAuth client type must be
# "iOS" or "Android", NOT "Web", or Google will require a secret with no safe
# place to live in a mobile app. Enable the YouTube Data API v3.
# Register redirect URI: bankaimusic://connect/youtubeMusic
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# Song ID — the app talks to a small Cloudflare Worker proxy, never to AudD
# directly, so the real (billed) AudD token never ships inside the app.
# Deploy server/identify-proxy first (see its README), then fill these in:
# the URL is just an endpoint and the key only gates casual abuse of your
# free AudD quota — neither is a secret worth protecting the way the AudD
# token itself is, which is why both are safe as EXPO_PUBLIC_ values.
EXPO_PUBLIC_IDENTIFY_PROXY_URL=
EXPO_PUBLIC_IDENTIFY_PROXY_KEY=
